    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "axe-playwright": "^2.2.2",
    "bundlesize2": "^0.0.35",
    "jest-axe": "^10.0.0",
    "jsdom": "^24.0.0",
    "lost-pixel": "^3.22.0",
    "msw": "^2.1.4",
    "postcss": "^8.4.33",

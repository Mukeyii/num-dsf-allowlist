{
  "name": "dsf-allowlist-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "node dist/index.js",
    "migrate": "node -r ts-node/register src/db/migrate.ts",
    "sync:cas": "node -r ts-node/register/transpile-only src/scripts/sync-mozilla-cas.ts",
    "test": "NODE_ENV=test jest --forceExit --detectOpenHandles",
    "test:coverage": "NODE_ENV=test jest --coverage --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.10",
    "mysql2": "^3.22.5",
    "node-cron": "^4.2.1",
    "node-forge": "^1.4.0",
    "nodemailer": "^9.0.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^5.0.0",
    "speakeasy": "^2.0.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "tar": "^7.5.11",

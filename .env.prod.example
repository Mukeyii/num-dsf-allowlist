# Production env template — copy to `.env.prod` (gitignored) and fill in.
# NEVER edit this file with real secrets. Use `openssl rand` for random values:
#   openssl rand -base64 32   # for passwords
#   openssl rand -hex 24      # for tokens / API keys
# JWT keys: use scripts/generate-keys.sh

NODE_ENV=production
PORT=3000
FRONTEND_URL=https://allowlist.imi.uni-muenster.de

DB_HOST=db
DB_PORT=3306
DB_NAME=dsf_allowlist
DB_USER=dsf
DB_PASSWORD=<GENERATE_WITH_openssl_rand_-base64_32>
DB_ROOT_PASSWORD=<GENERATE_WITH_openssl_rand_-base64_32>

# REDIS_URL must include the same password as REDIS_PASSWORD below — keep them in sync.
REDIS_URL=redis://:<GENERATE_WITH_openssl_rand_-hex_24>@redis:6379
REDIS_PASSWORD=<GENERATE_WITH_openssl_rand_-hex_24>

JWT_PRIVATE_KEY_BASE64=GENERIERT_MIT_generate-keys.sh
JWT_PUBLIC_KEY_BASE64=GENERIERT_MIT_generate-keys.sh
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

TOTP_ENCRYPTION_KEY=GENERIERT_MIT_generate-keys.sh

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=<SENDGRID_API_KEY_FROM_DASHBOARD>
MAIL_FROM=noreply@imi.uni-muenster.de

DSF_ENVIRONMENT=PRODUCTION
DSF_ENV_COLOR=#4d41df

RATE_LIMIT_OTP_MAX=5
RATE_LIMIT_OTP_WINDOW_MS=900000
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW_MS=60000

IMI_ADMIN_EMAILS=dsf-admin@imi.uni-muenster.de
VITE_API_URL=https://allowlist.imi.uni-muenster.de
